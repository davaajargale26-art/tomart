NODE_ENV=development
PORT=8890
TRUST_PROXY=false

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=loginapp
DB_SSL=false
DB_CONNECT_TIMEOUT_MS=10000

JWT_SECRET=replace_with_long_random_secret
ADMIN_SESSION_TTL=6h
ADMIN_LOGIN_RATE_LIMIT=10
SENSITIVE_RATE_LIMIT=120
ADMIN_EMAIL=
ADMIN_NAME=Site Admin
ADMIN_PASSWORD=
# Prefer ADMIN_PASSWORD_HASH instead of ADMIN_PASSWORD on production when possible.
ADMIN_PASSWORD_HASH=

# Leave blank when frontend and backend are served by the same Render service.
# Set to the backend Render URL only when the frontend is hosted separately.
VITE_API_URL=
REACT_APP_API_URL=
API_URL=

ALLOWED_ORIGINS=http://localhost:8890,http://localhost:5500,http://127.0.0.1:5500

# Required for production image uploads. Without Cloudinary, uploads return 503 instead of stopping the server.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tomujin-article
